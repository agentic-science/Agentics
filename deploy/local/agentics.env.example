# Agentics local development environment.
# Source from the repository root before running local foreground processes.

RUST_LOG=info
AGENTICS_LOG_LEVEL=info

AGENTICS_POSTGRES_PORT=5432
AGENTICS_DATABASE_URL=postgres://agentics:agentics@127.0.0.1:5432/agentics
AGENTICS_DEMO_DATABASE_URL=postgres://agentics:agentics@127.0.0.1:5432/agentics_demo
AGENTICS_CHALLENGES_ROOT=examples/challenges
AGENTICS_STORAGE_BACKEND=local
AGENTICS_STORAGE_ROOT=storage
AGENTICS_STORAGE_WORK_ROOT=$PWD/storage-work
AGENTICS_STORAGE_MAX_BUNDLE_ARCHIVE_BYTES=1073741824
AGENTICS_STORAGE_MAX_STATEMENT_BYTES=1048576
AGENTICS_STORAGE_MAX_JSON_ARTIFACT_BYTES=1048576
AGENTICS_STORAGE_TMP_OBJECT_GRACE_HOURS=24

AGENTICS_API_HOST=127.0.0.1
AGENTICS_API_PORT=3100
AGENTICS_WEB_PORT=3001
AGENTICS_API_BASE_URL=http://127.0.0.1:3100
AGENTICS_WEB_BASE_URL=http://127.0.0.1:3001
AGENTICS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
NEXT_PUBLIC_AGENTICS_API_BASE_URL=
AGENTICS_MOLTBOOK_SUBMOLT_NAME=agentics-platform
AGENTICS_MOLTBOOK_SUBMOLT_URL=https://www.moltbook.com/m/agentics-platform

AGENTICS_ADMIN_USERNAME=admin
AGENTICS_ADMIN_PASSWORD=change-me
AGENTICS_WEB_SESSION_COOKIE_SECURE=false
AGENTICS_AGENT_REGISTRATION_MODE=pioneer_code

AGENTICS_MAX_ACTIVE_AGENTS=100
AGENTICS_VALIDATION_RUNS_PER_AGENT_CHALLENGE_DAY=10
AGENTICS_OFFICIAL_RUNS_PER_AGENT_CHALLENGE_DAY=3
AGENTICS_MAX_ACTIVE_OFFICIAL_JOBS=2
