# Agentics Docker Compose development defaults.
# Dynamic host-visible paths are supplied by the just recipes.

RUST_LOG=info
AGENTICS_LOG_LEVEL=info
AGENTICS_RUST_TOOLCHAIN_IMAGE=agentics-rust-toolchain:bookworm-llvm22-local

AGENTICS_POSTGRES_USER=agentics
AGENTICS_POSTGRES_PASSWORD=agentics
AGENTICS_POSTGRES_DB=agentics_dev
AGENTICS_POSTGRES_PORT=55432
AGENTICS_DATABASE_URL=postgres://agentics:agentics@postgres:5432/agentics_dev
AGENTICS_LOCAL_DEV_DATABASE_NAME=agentics_dev
AGENTICS_LOCAL_DEV_DATABASE_URL=postgres://agentics:agentics@postgres:5432/agentics_dev
AGENTICS_LOCAL_DEV_DATABASE_URL_CONFIRM=non-loopback-local-dev-db

# Compose prepares this root from the local development challenge catalog.
AGENTICS_LOCAL_DEV_CHALLENGE_SOURCE_ROOT=/workspace/Agentics/challenge-repos/agentics-challenges/dev/challenges
AGENTICS_LOCAL_DEV_TEST_SOLUTIONS_ROOT=/workspace/Agentics/challenge-repos/agentics-challenges/dev/test-solutions
AGENTICS_CHALLENGES_ROOT=/workspace/Agentics/.agentics-compose/dev/dev-challenges
AGENTICS_RUSTFS_ACCESS_KEY=agenticsrustfs
AGENTICS_RUSTFS_SECRET_KEY=agenticsrustfssecret
AGENTICS_RUSTFS_PORT=9000
AGENTICS_RUSTFS_CONSOLE_PORT=9001
AGENTICS_STORAGE_BACKEND=s3
AGENTICS_S3_BUCKET=agentics
AGENTICS_S3_PREFIX=dev
AGENTICS_S3_REGION=us-east-1
AGENTICS_S3_ENDPOINT_URL=http://rustfs:9000
AGENTICS_S3_FORCE_PATH_STYLE=true
AGENTICS_STORAGE_MAX_BUNDLE_ARCHIVE_BYTES=1073741824
AGENTICS_STORAGE_MAX_STATEMENT_BYTES=1048576
AGENTICS_STORAGE_MAX_JSON_ARTIFACT_BYTES=1048576
AGENTICS_STORAGE_TMP_OBJECT_GRACE_HOURS=24

AGENTICS_API_HOST=0.0.0.0
AGENTICS_API_PORT=3100
AGENTICS_WEB_HOST=0.0.0.0
AGENTICS_WEB_PORT=3001
AGENTICS_API_BASE_URL=http://api:3100
AGENTICS_WEB_BASE_URL=http://localhost:3001
AGENTICS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
AGENTICS_WEB_ALLOWED_DEV_ORIGINS=127.0.0.1,localhost
NEXT_PUBLIC_AGENTICS_API_BASE_URL=

AGENTICS_MOLTBOOK_SUBMOLT_NAME=agentics-platform
AGENTICS_MOLTBOOK_SUBMOLT_URL=https://www.moltbook.com/m/agentics-platform

AGENTICS_BOOTSTRAP_ADMIN_GITHUB_USER_IDS=
AGENTICS_WEB_SESSION_COOKIE_SECURE=false
AGENTICS_AGENT_REGISTRATION_MODE=pioneer_code
AGENTICS_OFFICIAL_LOG_REDACTION=contract_based

AGENTICS_MAX_ACTIVE_AGENTS=100
AGENTICS_VALIDATION_RUNS_PER_AGENT_CHALLENGE_DAY=10
AGENTICS_OFFICIAL_RUNS_PER_AGENT_CHALLENGE_DAY=3
AGENTICS_MAX_ACTIVE_OFFICIAL_JOBS=2
