# Agentics disposable production rehearsal defaults.
#
# Copy this file to deploy/compose/env/rehearsal.env and replace every
# placeholder before running `just rehearsal::*` commands. Do not commit
# rehearsal.env. This environment is intentionally disposable and must never
# point at real production database, object storage, runner roots, or Docker
# sockets.

AGENTICS_DEPLOYMENT_STAGE=rehearsal
AGENTICS_LOG_LEVEL=info

AGENTICS_COMPOSE_PROD_PROJECT=agentics-rehearsal
AGENTICS_COMPOSE_BIND_IP=127.0.0.1
COMPOSE_PROFILES=gpu

AGENTICS_POSTGRES_USER=agentics
AGENTICS_POSTGRES_PASSWORD=replace-with-rehearsal-postgres-password
AGENTICS_POSTGRES_DB=agentics_rehearsal
AGENTICS_POSTGRES_PORT=15432
AGENTICS_DATABASE_URL=postgres://agentics:replace-with-rehearsal-postgres-password@127.0.0.1:15432/agentics_rehearsal

AGENTICS_RUSTFS_ACCESS_KEY=replace-with-rehearsal-rustfs-access-key
AGENTICS_RUSTFS_SECRET_KEY=replace-with-rehearsal-rustfs-secret-key
AGENTICS_RUSTFS_PORT=19000
AGENTICS_RUSTFS_CONSOLE_PORT=19001

AGENTICS_STORAGE_BACKEND=s3
AGENTICS_S3_BUCKET=agentics-rehearsal
AGENTICS_S3_PREFIX=rehearsal
AGENTICS_S3_REGION=us-east-1
AGENTICS_S3_ENDPOINT_URL=http://rustfs:9000
AGENTICS_REHEARSAL_HOST_S3_ENDPOINT_URL=http://127.0.0.1:19000
AGENTICS_S3_FORCE_PATH_STYLE=true
AGENTICS_STORAGE_WORK_ROOT=/srv/agentics-rehearsal/storage-work
AGENTICS_STORAGE_MAX_BUNDLE_ARCHIVE_BYTES=1073741824
AGENTICS_STORAGE_MAX_STATEMENT_BYTES=1048576
AGENTICS_STORAGE_MAX_JSON_ARTIFACT_BYTES=1048576
AGENTICS_STORAGE_TMP_OBJECT_GRACE_HOURS=24

AGENTICS_CHALLENGE_REVIEW_REPOSITORY_HOST_ROOT=/srv/agentics-rehearsal/review-checkouts/agentics-challenges
AGENTICS_CHALLENGE_REVIEW_REPOSITORY_CONTAINER_ROOT=/srv/agentics-rehearsal/review-checkouts/agentics-challenges

AGENTICS_API_HOST=0.0.0.0
AGENTICS_API_PORT=3100
AGENTICS_API_HOST_PORT=13100
AGENTICS_WEB_PORT=3001
AGENTICS_WEB_HOST_PORT=13001
AGENTICS_API_BASE_URL=http://127.0.0.1:13100
AGENTICS_WEB_BASE_URL=http://127.0.0.1:13001
AGENTICS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:13001,http://localhost:13001
AGENTICS_WEB_ALLOWED_DEV_ORIGINS=
NEXT_PUBLIC_AGENTICS_API_BASE_URL=
NEXT_PUBLIC_AGENTICS_GA_MEASUREMENT_ID=

AGENTICS_MOLTBOOK_SUBMOLT_NAME=agentics-platform
AGENTICS_MOLTBOOK_SUBMOLT_URL=https://www.moltbook.com/m/agentics-platform

AGENTICS_BOOTSTRAP_ADMIN_GITHUB_USER_IDS=replace-with-rehearsal-github-numeric-user-id
AGENTICS_WEB_SESSION_COOKIE_SECURE=false
AGENTICS_AGENT_REGISTRATION_MODE=pioneer_code

AGENTICS_GITHUB_APP_CLIENT_ID=replace-with-rehearsal-github-app-client-id
AGENTICS_GITHUB_APP_CLIENT_SECRET=replace-with-rehearsal-github-app-client-secret
AGENTICS_GITHUB_APP_REDIRECT_URL=http://127.0.0.1:13001/auth/github/callback

AGENTICS_DGX_STATE_ROOT=/srv/agentics-rehearsal
AGENTICS_DOCKER_SOCKET_PATH=/srv/agentics-rehearsal/docker.sock
AGENTICS_DOCKER_HOST=unix:///srv/agentics-rehearsal/docker.sock
AGENTICS_RUNNER_NAMESPACE=agentics-rehearsal
AGENTICS_RUNTIME_UID=10001
AGENTICS_RUNTIME_GID=10001
AGENTICS_DOCKER_SOCKET_GID=10001

AGENTICS_RUNNER_SECURITY_PROFILE=production
AGENTICS_OFFICIAL_LOG_REDACTION=always
AGENTICS_HOST_PROBE_MODE=require
AGENTICS_HOST_PROBE_COMMAND=/usr/local/bin/agentics-check-dgx-spark-profile
AGENTICS_REQUIRE_DIGEST_PINNED_IMAGES=true
AGENTICS_WORKER_ACCELERATORS=none
AGENTICS_WORKER_GPU_PROBE_IMAGE=ghcr.io/agentic-science/agentics-linux-arm64-cuda:cu130-ubuntu24.04-v0.2.5@sha256:8e3da4a65e297e3b1e9800da001fa2bbac9ed48453a6972117a0c3ad1d1eef13
AGENTICS_RUNNER_WRITABLE_STORAGE_MODE=xfs-project-quota-slots
AGENTICS_DGX_DOCKER_DATA_ROOT=/srv/agentics-rehearsal/docker-data-root
AGENTICS_DGX_RUNNER_DOCKER_EXEC_ROOT=/srv/agentics-rehearsal/docker-exec
AGENTICS_DGX_RUNNER_DOCKER_PIDFILE=/srv/agentics-rehearsal/docker.pid
AGENTICS_DGX_RUNNER_DOCKER_LOG=/srv/agentics-rehearsal/dockerd.log
AGENTICS_DGX_RUNNER_DOCKER_BRIDGE=agenticsrh0
AGENTICS_DGX_RUNNER_DOCKER_BRIDGE_CIDR=172.31.0.1/16
AGENTICS_RUNNER_RUNTIME_ROOT=/srv/agentics-rehearsal/runtime
AGENTICS_RUNNER_PHASE_MOUNT_ROOT=/srv/agentics-rehearsal/phase-mounts
AGENTICS_DGX_PHASE_MOUNT_ROOT=/srv/agentics-rehearsal/phase-mounts
AGENTICS_RUNNER_WRITABLE_SLOT_CLASSES_MB=64,256,1024,4096,8192,12288,16384
AGENTICS_DGX_PHASE_SLOT_CLASSES_MB=64,256,1024,4096,8192,12288,16384
AGENTICS_DGX_PHASE_SLOTS_PER_CLASS=100
AGENTICS_DGX_PHASE_SLOT_INODES_PER_MB=256
AGENTICS_DGX_PERSIST_FSTAB=false
AGENTICS_RUNNER_DOCKER_LAYER_QUOTA=true
AGENTICS_DGX_RUN_MUTATING_PROBES=true
AGENTICS_RUNNER_MAX_OUTPUT_FILES=8192
AGENTICS_RUNNER_MAX_OUTPUT_DIRS=1024
AGENTICS_RUNNER_MAX_OUTPUT_DEPTH=32
AGENTICS_RUNNER_MAX_RUNS=100
AGENTICS_RUNNER_MAX_RESULT_JSON_BYTES=4194304
AGENTICS_RUNNER_MAX_PUBLIC_RESULTS=1024
AGENTICS_RUNNER_MAX_RESULT_LOG_BYTES=262144
AGENTICS_RUNNER_MAX_INTERACTION_BYTES_PER_DIRECTION=268435456
AGENTICS_RUNNER_INTERACTION_SHUTDOWN_GRACE_SECS=2

AGENTICS_REHEARSAL_CPU_IMAGE_SOURCE=registry
AGENTICS_REHEARSAL_CPU_IMAGE_REFERENCE=ghcr.io/agentic-science/agentics-linux-arm64-cpu:ubuntu26.04-v0.2.5@sha256:7ba1dbfb4de62ce7c8716fbdf6fa9e840004cc2d231ac9c0adfd655cd275a537

AGENTICS_MAX_ACTIVE_AGENTS=100
AGENTICS_VALIDATION_RUNS_PER_AGENT_CHALLENGE_DAY=10
AGENTICS_OFFICIAL_RUNS_PER_AGENT_CHALLENGE_DAY=3
AGENTICS_MAX_ACTIVE_OFFICIAL_JOBS=2
AGENTICS_MAX_ACTIVE_CHALLENGE_REVIEW_RECORDS_PER_HUMAN=3
AGENTICS_CHALLENGE_PRIVATE_ASSET_BYTES_PER_REVIEW_RECORD=262144000
AGENTICS_CHALLENGE_REVIEW_RECORD_VALIDATIONS_PER_DAY=10
AGENTICS_CHALLENGE_REVIEW_RECORD_TTL_DAYS=14
AGENTICS_UNPUBLISHED_CHALLENGE_ASSET_GRACE_DAYS=7
