# Agentics Docker Compose integration-test defaults.
# The quota roots must be prepared on the host before running the full suite.

AGENTICS_DEPLOYMENT_STAGE=test
AGENTICS_LOG_LEVEL=info
AGENTICS_RUST_TOOLCHAIN_IMAGE=agentics-rust-toolchain:bookworm-llvm22-local

AGENTICS_POSTGRES_USER=agentics
AGENTICS_POSTGRES_PASSWORD=agentics
AGENTICS_POSTGRES_DB=agentics_test
DATABASE_URL=postgres://agentics:agentics@postgres:5432/agentics_test
AGENTICS_DATABASE_URL=postgres://agentics:agentics@postgres:5432/agentics_test

AGENTICS_RUSTFS_ACCESS_KEY=agenticsrustfs
AGENTICS_RUSTFS_SECRET_KEY=agenticsrustfssecret
AGENTICS_STORAGE_BACKEND=s3
AGENTICS_S3_BUCKET=agentics
AGENTICS_S3_PREFIX=test/local
AGENTICS_S3_REGION=us-east-1
AGENTICS_S3_ENDPOINT_URL=http://rustfs:9000
AGENTICS_S3_FORCE_PATH_STYLE=true

# Compose integration tests keep Cargo caches warm by default. Set
# AGENTICS_TEST_DISABLE_CARGO_CACHE=true for cold-cache verification.
AGENTICS_TEST_DISABLE_CARGO_CACHE=false
AGENTICS_TEST_CARGO_REGISTRY_VOLUME=agentics-test-cargo-registry
AGENTICS_TEST_CARGO_GIT_VOLUME=agentics-test-cargo-git
AGENTICS_TEST_CARGO_TARGET_VOLUME=agentics-test-cargo-target

AGENTICS_STORAGE_MAX_BUNDLE_ARCHIVE_BYTES=1073741824
AGENTICS_STORAGE_MAX_STATEMENT_BYTES=1048576
AGENTICS_STORAGE_MAX_JSON_ARTIFACT_BYTES=1048576
AGENTICS_STORAGE_TMP_OBJECT_GRACE_HOURS=24

AGENTICS_API_HOST=127.0.0.1
AGENTICS_API_PORT=0
AGENTICS_WEB_PORT=3001
AGENTICS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
AGENTICS_BOOTSTRAP_ADMIN_GITHUB_USER_IDS=9001
AGENTICS_AGENT_REGISTRATION_MODE=public
AGENTICS_WEB_SESSION_COOKIE_SECURE=false
NEXT_PUBLIC_AGENTICS_GA_MEASUREMENT_ID=

AGENTICS_TEST_RUNNER_WRITABLE_STORAGE_MODE=xfs-project-quota-slots
AGENTICS_TEST_RUNNER_WRITABLE_SLOT_CLASSES_MB=64,256,1024,4096
AGENTICS_TEST_RUNNER_DOCKER_LAYER_QUOTA=true

# The test container talks to this dedicated Docker daemon for runner containers.
# Start it with: sudo env AGENTICS_TEST_ROOT=/srv/agentics-test just test-env-up
AGENTICS_TEST_DOCKER_HOST=unix:///srv/agentics-test/docker.sock
AGENTICS_TEST_DOCKER_SOCKET_PATH=/srv/agentics-test/docker.sock
