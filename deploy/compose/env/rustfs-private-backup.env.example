# Persistent RustFS backup store for migrated challenge private bundles.
#
# Copy this file to deploy/compose/env/rustfs-private-backup.env for local use.
# This service is not the Agentics durable storage backend. It is a stable,
# LAN-accessible object store for backing up private bundle ZIPs between
# production deployment rehearsals.

AGENTICS_RUSTFS_BACKUP_BIND_IP=0.0.0.0
AGENTICS_RUSTFS_BACKUP_API_PORT=9100
AGENTICS_RUSTFS_BACKUP_CONSOLE_PORT=9101
AGENTICS_RUSTFS_BACKUP_DATA_DIR=/srv/agentics-private-bundle-backups/rustfs-data
AGENTICS_RUSTFS_BACKUP_BUCKET=migrated-challenge-private-bundles
AGENTICS_RUSTFS_BACKUP_ACCESS_KEY=agenticsprivatebundlebackup
AGENTICS_RUSTFS_BACKUP_SECRET_KEY=agenticsprivatebundlebackuplocalonly
