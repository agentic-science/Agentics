[Unit]
Description=Agentics-owned Docker daemon
Documentation=https://docs.docker.com/engine/
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
ExecStart=/usr/bin/dockerd --config-file=/etc/agentics/dockerd-agentics.json --host=unix:///run/agentics/docker.sock --group=agentics --pidfile=/run/agentics/docker.pid --exec-root=/run/agentics/docker-exec --containerd-namespace=agentics --containerd-plugins-namespace=agentics-plugins
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
RestartSec=5s
RuntimeDirectory=agentics
RuntimeDirectoryMode=0755
LimitNOFILE=1048576
LimitNPROC=infinity
LimitCORE=infinity
TasksMax=infinity
Delegate=yes
KillMode=process
OOMScoreAdjust=-500

[Install]
WantedBy=multi-user.target
