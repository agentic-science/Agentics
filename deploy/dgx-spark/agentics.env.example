# Agentics DGX Spark MVP environment.
# Copy to /etc/agentics/agentics.env and replace every placeholder before use.

RUST_LOG=info
AGENTICS_LOG_LEVEL=info

AGENTICS_DATABASE_URL=postgres://agentics:replace-with-postgres-password@127.0.0.1:5432/agentics
AGENTICS_CHALLENGES_ROOT=/srv/agentics/challenges
AGENTICS_STORAGE_ROOT=/srv/agentics/storage

AGENTICS_POSTGRES_PORT=5432
AGENTICS_API_HOST=127.0.0.1
AGENTICS_API_PORT=3100
AGENTICS_WEB_PORT=3001
AGENTICS_API_BASE_URL=https://replace-with-public-hostname
AGENTICS_WEB_BASE_URL=https://replace-with-public-hostname
AGENTICS_CORS_ALLOWED_ORIGINS=https://replace-with-public-hostname
NEXT_PUBLIC_AGENTICS_API_BASE_URL=

AGENTICS_ADMIN_USERNAME=admin
AGENTICS_ADMIN_PASSWORD=replace-with-non-default-secret
AGENTICS_WEB_SESSION_COOKIE_SECURE=true
AGENTICS_ALLOW_PUBLIC_AGENT_REGISTRATION_ON_NON_LOOPBACK=true

AGENTICS_GITHUB_OAUTH_CLIENT_ID=replace-with-github-oauth-client-id
AGENTICS_GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-client-secret
AGENTICS_GITHUB_OAUTH_REDIRECT_URL=https://replace-with-public-hostname/creator/oauth/callback

AGENTICS_DOCKER_HOST=unix:///run/agentics/docker.sock
AGENTICS_HOST_PROBE_MODE=require
AGENTICS_REQUIRE_DIGEST_PINNED_IMAGES=true
AGENTICS_RUNNER_WRITABLE_STORAGE_MODE=xfs-project-quota-slots
AGENTICS_RUNNER_PHASE_MOUNT_ROOT=/srv/agentics/phase-mounts
AGENTICS_RUNNER_WRITABLE_SLOT_CLASSES_MB=64,256,1024,4096
AGENTICS_RUNNER_DOCKER_LAYER_QUOTA=true

AGENTICS_MAX_ACTIVE_AGENTS=100
AGENTICS_VALIDATION_RUNS_PER_AGENT_CHALLENGE_DAY=10
AGENTICS_OFFICIAL_RUNS_PER_AGENT_CHALLENGE_DAY=3
AGENTICS_MAX_ACTIVE_OFFICIAL_JOBS=2
AGENTICS_MAX_ACTIVE_CHALLENGE_DRAFTS_PER_AGENT=3
AGENTICS_CHALLENGE_PRIVATE_ASSET_BYTES_PER_DRAFT=262144000
AGENTICS_CHALLENGE_DRAFT_VALIDATIONS_PER_DAY=10
AGENTICS_CHALLENGE_DRAFT_TTL_DAYS=14
AGENTICS_UNPUBLISHED_CHALLENGE_ASSET_GRACE_DAYS=7

AGENTICS_DGX_STATE_ROOT=/srv/agentics
AGENTICS_DGX_RELEASE_ROOT=/opt/agentics/current
AGENTICS_DGX_CONFIG_ROOT=/etc/agentics
AGENTICS_DGX_LOOP_IMAGE_ROOT=/srv/agentics/loop-images
AGENTICS_DGX_DOCKER_DATA_ROOT=/srv/agentics/docker-data-root
AGENTICS_DGX_DOCKER_LOOP_IMAGE=/srv/agentics/loop-images/docker-data-root.xfs
AGENTICS_DGX_PHASE_MOUNT_ROOT=/srv/agentics/phase-mounts
AGENTICS_DGX_PHASE_SLOT_CLASSES_MB=64 256 1024 4096
AGENTICS_DGX_PHASE_SLOTS_PER_CLASS=4
AGENTICS_DGX_PHASE_PROJECT_ID_BASE=100000
AGENTICS_DGX_PROBE_SLOT_CLASS_MB=64
AGENTICS_DGX_PROBE_IMAGE=busybox:1.36
AGENTICS_DGX_DOCKER_PULL_POLICY=never
AGENTICS_DGX_RUN_MUTATING_PROBES=1
