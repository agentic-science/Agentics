{
  "bridge": "none",
  "data-root": "/srv/agentics/docker-data-root",
  "exec-opts": ["native.cgroupdriver=systemd"],
  "icc": false,
  "iptables": true,
  "live-restore": true,
  "log-driver": "json-file",
  "log-opts": {
    "max-file": "3",
    "max-size": "10m"
  },
  "runtimes": {
    "nvidia": {
      "args": [],
      "path": "nvidia-container-runtime"
    }
  },
  "storage-driver": "overlay2"
}
