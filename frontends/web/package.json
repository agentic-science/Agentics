    "gifenc": "^1.0.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
