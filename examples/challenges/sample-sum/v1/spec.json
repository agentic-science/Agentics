{
  "schema_version": 1,
  "challenge_name": "sample-sum",
  "challenge_title": "Sample Sum",
  "summary": {
    "en": "Add numbers across evaluator-controlled public and private benchmark runs.",
    "zh": "在 evaluator 控制的公开和私有基准运行中完成数字求和。"
  },
  "keywords": ["arithmetic", "public private", "starter"],
  "solution": {
    "protocol": "zip_project",
    "manifest_file": "agentics.solution.json"
  },
  "targets": [
    {
      "name": "linux-arm64-cpu",
      "docker_platform": "linux/arm64",
      "accelerator": null,
      "validation_enabled": true,
      "resource_profile": {
        "name": "agentics-cpu-small",
        "solution_image": {
          "source": "local",
          "reference": "agentics-linux-arm64-cpu:ubuntu26.04-local"
        },
        "evaluator_image": {
          "source": "local",
          "reference": "agentics-linux-arm64-cpu:ubuntu26.04-local"
        },
        "solution": {
          "setup": {
            "timeout_sec": 30,
            "memory_limit_mb": 512,
            "cpu_limit_millis": 1000,
            "disk_limit_mb": 1024,
            "network_access": "enabled"
          },
          "build": {
            "timeout_sec": 30,
            "memory_limit_mb": 512,
            "cpu_limit_millis": 1000,
            "disk_limit_mb": 1024,
            "network_access": "disabled"
          },
          "run": {
            "timeout_sec": 30,
            "memory_limit_mb": 512,
            "cpu_limit_millis": 1000,
            "disk_limit_mb": 1024,
            "network_access": "disabled"
          }
        },
        "evaluator": {
          "setup": {
            "timeout_sec": 30,
            "memory_limit_mb": 512,
            "cpu_limit_millis": 1000,
            "disk_limit_mb": 1024,
            "network_access": "enabled"
          },
          "run": {
            "timeout_sec": 30,
            "memory_limit_mb": 512,
            "cpu_limit_millis": 1000,
            "disk_limit_mb": 1024,
            "network_access": "disabled"
          }
        },
        "resource_description": "Single CPU worker profile for protocol fixtures.",
        "hardware_metadata": {
          "kind": "cpu"
        }
      }
    }
  ],
  "starts_at": "2026-01-01T00:00:00Z",
  "eligibility": { "type": "open" },
  "visibility": {
    "leaderboard": "public_live",
    "score_distribution": "public_live",
    "result_detail": "submitter_live_public_live"
  },
  "solution_publication": "public",
  "execution": {
    "mode": "separated_evaluator",
    "separated_evaluator": {
      "command": ["python", "separated-evaluator/run.py"],
      "result_file": "result.json"
    },
    "validation_runs": "public/runs.json",
    "official_runs": "private-benchmark/runs.json"
  },
  "datasets": {
    "public_dir": "public",
    "private_benchmark_dir": "private-benchmark",
    "public_policy": "full",
    "private_benchmark_policy": "score_only",
    "private_benchmark_enabled": true
  },
  "metric_schema": {
    "metrics": [
      {
        "name": "score",
        "label": "Score",
        "direction": "maximize",
        "visibility": "public",
        "metric_description": "Fraction of runs whose output exactly matches the expected value."
      },
      {
        "name": "passed_cases",
        "label": "Passed Cases",
        "unit": "cases",
        "direction": "maximize",
        "visibility": "public",
        "metric_description": "Number of evaluated runs that passed."
      }
    ],
    "ranking": {
      "primary_metric_name": "score",
      "tie_breaker_metric_names": ["passed_cases"]
    }
  }
}
